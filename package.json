{
  "name": "carbonx",
  "version": "1.0.0",
  "private": true,
  "description": "CarbonX climate-fintech dashboard for SMEs",
  "scripts": {
    "carbonx": "npm run install:all && node scripts/dev.js",
    "dev": "node scripts/dev.js",
    "seed": "node server/seed.js",
    "start": "node server/index.js",
    "build": "npm --prefix client run build",
    "postinstall": "npm --prefix client install",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {}
}
